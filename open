#!/usr/bin/env bash
set -euo pipefail

VERSION="1.0.0"

die() {
  echo "open: $*" >&2
  exit 1
}

usage() {
  cat <<'EOF'
Usage: open [-a app] [-DeRtWfg] [target ...]

Open files, directories, and URLs from WSL using Windows applications.

Flags:
  -a <app>     Open with a specific Windows application
  -D           Open the enclosing folder in Explorer
  -R           Reveal in Explorer (highlight the file)
  -e           Open in text editor (VS Code or $WSL_OPEN_EDITOR)
  -t           Alias for -e
  -W           Wait for the application to exit
  -f           Read stdin into a temp file, then open it
  -g           Open in background (no-op; Windows apps already detach)
  -h, --help   Show this help
  -V, --version  Show version
EOF
}

version() {
  echo "open $VERSION (WSL)"
}

is_url() {
  [[ "$1" =~ ^https?:// || "$1" =~ ^mailto: || "$1" =~ ^ftp:// ]]
}

to_winpath() {
  [[ -e "$1" ]] || die "no such file or directory: $1"
  wslpath -aw "$1" 2>/dev/null || die "cannot convert path: $1"
}


# --- Argument parsing ---

flag_enclosing=false
flag_reveal=false
flag_editor=false
flag_wait=false
flag_stdin=false
flag_background=false
app=""
targets=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)    usage; exit 0 ;;
    -V|--version) version; exit 0 ;;
    -D)           flag_enclosing=true; shift ;;
    -R)           flag_reveal=true; shift ;;
    -e|-t)        flag_editor=true; shift ;;
    -W)           flag_wait=true; shift ;;
    -f)           flag_stdin=true; shift ;;
    -g)           flag_background=true; shift ;;
    -a)
      [[ -n "${2:-}" ]] || die "-a requires an application name"
      app="$2"; shift 2 ;;
    --)           shift; targets+=("$@"); break ;;
    -*)           die "unknown option: $1" ;;
    *)            targets+=("$1"); shift ;;
  esac
done

# --- Stdin mode ---

tmpfile=""
cleanup() {
  [[ -n "$tmpfile" && -f "$tmpfile" ]] && rm -f "$tmpfile"
}
trap cleanup EXIT

if $flag_stdin; then
  tmpfile="$(mktemp /tmp/wsl-open-XXXXXX)"
  cat > "$tmpfile"
  targets+=("$tmpfile")
fi

# --- Validate targets ---

if [[ ${#targets[@]} -eq 0 ]]; then
  die "no target specified (use -h for help)"
fi

# --- Dispatch ---

open_target() {
  local target="$1"

  if is_url "$target"; then
    cmd.exe /C start "" "$target" 2>/dev/null
  elif $flag_enclosing; then
    local parent winpath
    parent="$(dirname "$target")"
    winpath="$(to_winpath "$parent")"
    explorer.exe "$winpath" 2>/dev/null
  elif $flag_reveal; then
    local winpath
    winpath="$(to_winpath "$target")"
    explorer.exe /select,"$winpath" 2>/dev/null
  elif $flag_editor; then
    local editor="${WSL_OPEN_EDITOR:-notepad.exe}"
    local editor_path
    editor_path="$(command -v "$editor" 2>/dev/null)" || die "editor not found: $editor"
    if [[ "$editor_path" == /mnt/* ]]; then
      "$editor" "$(to_winpath "$target")"
    else
      "$editor" "$target"
    fi
  elif [[ -n "$app" ]]; then
    local winpath
    winpath="$(to_winpath "$target")"
    if $flag_wait; then
      cmd.exe /C start "" /WAIT "$app" "$winpath" 2>/dev/null
    else
      cmd.exe /C start "" "$app" "$winpath" 2>/dev/null
    fi
  elif [[ -d "$target" ]]; then
    local winpath
    winpath="$(to_winpath "$target")"
    explorer.exe "$winpath" 2>/dev/null
  else
    local winpath
    winpath="$(to_winpath "$target")"
    if $flag_wait; then
      cmd.exe /C start "" /WAIT "$winpath" 2>/dev/null
    else
      cmd.exe /C start "" "$winpath" 2>/dev/null
    fi
  fi
}

for target in "${targets[@]}"; do
  open_target "$target"
done
